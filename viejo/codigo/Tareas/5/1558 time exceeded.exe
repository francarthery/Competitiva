#include <iostream>
#include <cmath>
using namespace std;

int main(int argc, char *argv[]) {
	
	double R,N;
	
	while(cin >> N){
		if(N<=0)
			cout << "NO" << endl;
		
		else if(sqrt(N)-int(sqrt(N))==0)
			cout << "YES" << endl;
		
		else{
			for(int i=0; i<= int(sqrt(N)); i++){
				for(int X=0; X<=int(sqrt(N)) and R!=N; X++)
					R=pow(i,2)+pow(X,2);
			}
			if(R==N)
				cout << "YES" << endl;
			else
				cout << "NO" << endl;
		}

	}
	return 0;
}

	"primalidad": {
	"prefix": "primalidad",
	"body": [
		"bool isPrime(ll N){ //O(sqrt(n))",
		"    if(N == 2) return true;",
		"    if(N < 2 or N % 2 == 0) return false;",
		"    for(int i = 3; i * i <= N; i += 2)",
		"        if(N % i == 0) return false;",
		"",
		"    return true;",
		"}"
	],
	"description": "primalidad"
	},

	"exponenciacion_binaria": {
	"prefix": "exponenciacion_binaria",
	"body": [
		"ll expMod(ll b, ll e, ll m) {  // O(log e)",
		"    if (e < 0) return 0;",
		"    ll ret = 1;",
		"    while (e) {",
		"        if (e & 1) ret = ret * b % m;  // ret = mulMod(ret,b,m); //if needed",
		"        b = b * b % m;                 // b = mulMod(b,b,m);",
		"        e >>= 1;",
		"    }",
		"    return ret;",
		"}"
	],
	"description": "exponenciacion_binaria"
	}

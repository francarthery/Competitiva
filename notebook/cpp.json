	"body": [
		"bool cuad(ll n){",
		"    __int128_t l = 0, r = n;",
		"    while(r - l > 1){",
		"        __int128_t m = (l + r) / 2;",
		"        if(m * m < n) l = m;",
		"        else r = m; ",
		"    }",
		"    return r * r == n;",
		"}"
